# Copy to .env for local dev; set the same keys in the Vercel dashboard for prod.

# Supabase project REST URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Supabase service_role key (SERVER-SIDE ONLY — never expose to the browser).
# Bypasses RLS by design; all access control happens in lib/auth.js.
SUPABASE_SERVICE_KEY=

# Secret used to sign session JWTs. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
